# Docker Hub images
FOXMEMORY_INFER_IMAGE=docker.io/foxlightfoundation/foxmemory-infer:latest
FOXMEMORY_STORE_IMAGE=docker.io/foxlightfoundation/foxmemory-store:latest

# infer runtime
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b
INFER_API_KEY=

# store runtime (canonical contract)
# Internal default for one-node compose is service name `infer`.
OPENAI_BASE_URL=http://infer:8081/v1
OPENAI_API_KEY=
MEM0_LLM_MODEL=gpt-4.1-nano
MEM0_EMBED_MODEL=text-embedding-3-small

# Qdrant config
# Prefer QDRANT_URL when supported by the service runtime.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=foxmemory

# Backward-compatible fields used by some builds/scripts
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Analytics DB — persists write/search history across restarts.
# Must be on a mounted volume. Path is set per-compose-file; override here if needed.
# FOXMEMORY_ANALYTICS_DB_PATH=/qdrant/storage/foxmemory-analytics.db

# Graph memory (Neo4j) — optional.
# Set NEO4J_URL + NEO4J_PASSWORD to enable. Leave blank to disable.
# NEO4J_AUTH must match NEO4J_PASSWORD (format: neo4j/<password>).
# MEM0_GRAPH_LLM_MODEL: recommended gpt-4.1-mini (hosted) or Qwen2.5-14B-Instruct (local).
NEO4J_AUTH=neo4j/changeme
NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
MEM0_GRAPH_LLM_MODEL=gpt-4.1-mini
